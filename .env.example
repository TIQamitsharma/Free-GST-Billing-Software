# ============================================================
# GST Billing SaaS - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase project URL (required by frontend + backend)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (SERVER ONLY - never expose to frontend)
# Found in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server port (default: 3001)
PORT=3001

# CORS origin for production (set to your domain, e.g. https://yourdomain.com)
# Use * for development only
CORS_ORIGIN=*
